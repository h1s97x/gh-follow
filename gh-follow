#!/bin/bash
# gh-follow - GitHub CLI extension for managing follow relationships
# This script is used by 'gh extension install' to install the extension

set -e

EXTENSION_NAME="gh-follow"
REPO="h1s97x/gh-follow"
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"

# Detect OS and architecture
OS=$(uname -s | tr '[:upper:]' '[:lower:]')
ARCH=$(uname -m)

# Map architecture
case $ARCH in
    x86_64|amd64) ARCH="amd64" ;;
    aarch64|arm64) ARCH="arm64" ;;
    *)
        echo "⚠️  Unsupported architecture: $ARCH, building from source..."
        BUILD_FROM_SOURCE=true
        ;;
esac

# Map OS and set format
FORMAT="tar.gz"
case $OS in
    darwin) ;;
    linux) ;;
    mingw*|msys*|cygwin*|windows*)
        FORMAT="zip"
        ;;
    *)
        echo "⚠️  Unsupported OS: $OS, building from source..."
        BUILD_FROM_SOURCE=true
        ;;
esac

# Try to download pre-built binary
if [ "$BUILD_FROM_SOURCE" != true ]; then
    echo "🔍 Checking for pre-built binary..."
    
    # Get latest release using gh api
    LATEST=$(gh api "repos/${REPO}/releases/latest" 2>/dev/null || echo "")
    
    if [ -n "$LATEST" ] && [ "$LATEST" != "" ]; then
        # Extract tag_name using jq or fallback to grep/sed
        VERSION=""
        if command -v jq &> /dev/null; then
            VERSION=$(echo "$LATEST" | jq -r '.tag_name // empty')
        fi
        
        # Fallback: parse with grep/sed if jq not available or failed
        if [ -z "$VERSION" ]; then
            VERSION=$(echo "$LATEST" | grep '"tag_name"' | head -1 | sed -E 's/.*"tag_name"[[:space:]]*:[[:space:]]*"([^"]+)".*/\1/')
        fi
        
        # Remove 'v' prefix if present (e.g., v1.0.1 -> 1.0.1)
        VERSION_NUM="${VERSION#v}"
        
        if [ -n "$VERSION" ] && [ "$VERSION" != "" ]; then
            echo "📦 Found release: $VERSION"
            
            # Try multiple archive naming formats (in order of preference)
            # Format 1: gh-follow-{os}-{arch} (new format, matches current GoReleaser config)
            # Format 2: gh-follow_{version}_{os}_{arch} (old format with version)
            ARCHIVE_NAMES=(
                "${EXTENSION_NAME}-${OS}-${ARCH}"
                "${EXTENSION_NAME}_${VERSION_NUM}_${OS}_${ARCH}"
            )
            
            DOWNLOADED=false
            for ARCHIVE_NAME in "${ARCHIVE_NAMES[@]}"; do
                DOWNLOAD_URL="https://github.com/${REPO}/releases/download/${VERSION}/${ARCHIVE_NAME}.${FORMAT}"
                
                echo "   Trying: ${ARCHIVE_NAME}.${FORMAT}"
                
                TEMP_FILE="/tmp/${ARCHIVE_NAME}.${FORMAT}"
                
                if curl -sL "$DOWNLOAD_URL" -o "$TEMP_FILE" 2>/dev/null && [ -s "$TEMP_FILE" ]; then
                    echo "⬇️  Downloaded successfully, extracting..."
                    
                    # Extract to temp directory
                    TEMP_DIR=$(mktemp -d)
                    cd "$TEMP_DIR"
                    
                    if [ "$FORMAT" = "tar.gz" ]; then
                        tar -xzf "$TEMP_FILE" 2>/dev/null || true
                    else
                        unzip -q "$TEMP_FILE" 2>/dev/null || true
                    fi
                    
                    # Find the extracted binary (try multiple possible names)
                    EXTRACTED_BINARY=""
                    for BINARY_NAME in "${EXTENSION_NAME}" "${EXTENSION_NAME}.exe" "${ARCHIVE_NAME}" "${ARCHIVE_NAME}.exe"; do
                        if [ -f "$BINARY_NAME" ]; then
                            EXTRACTED_BINARY="$BINARY_NAME"
                            break
                        fi
                    done
                    
                    # Fallback: find any executable file
                    if [ -z "$EXTRACTED_BINARY" ]; then
                        EXTRACTED_BINARY=$(find . -maxdepth 1 -type f \( -name "${EXTENSION_NAME}" -o -name "${EXTENSION_NAME}.exe" \) 2>/dev/null | head -1)
                    fi
                    
                    if [ -n "$EXTRACTED_BINARY" ] && [ -f "$EXTRACTED_BINARY" ]; then
                        # Move to final location
                        mv "$EXTRACTED_BINARY" "$SCRIPT_DIR/$EXTENSION_NAME"
                        chmod +x "$SCRIPT_DIR/$EXTENSION_NAME"
                        
                        # Cleanup
                        rm -f "$TEMP_FILE"
                        rm -rf "$TEMP_DIR"
                        
                        echo "✅ Installed ${EXTENSION_NAME} ${VERSION}"
                        DOWNLOADED=true
                        exit 0
                    else
                        echo "⚠️  Binary not found in archive, contents:"
                        ls -la 2>/dev/null || true
                        rm -rf "$TEMP_DIR"
                    fi
                    
                    rm -f "$TEMP_FILE"
                fi
            done
            
            if [ "$DOWNLOADED" = false ]; then
                echo "⚠️  Could not download pre-built binary for ${OS}-${ARCH}"
            fi
        fi
    fi
    
    echo "⚠️  Pre-built binary not available, building from source..."
fi

# Build from source
echo "🔨 Building from source..."

# Check if Go is installed
if ! command -v go &> /dev/null; then
    echo "❌ Error: Go is not installed."
    echo ""
    echo "Please install Go from: https://golang.org/doc/install"
    echo ""
    echo "Or download a pre-built binary from:"
    echo "https://github.com/${REPO}/releases"
    exit 1
fi

GO_VERSION=$(go version 2>/dev/null | awk '{print $3}' | sed 's/go//')
echo "   Go version: $GO_VERSION"

# Build in a temp directory to avoid conflicts
TEMP_BUILD_DIR=$(mktemp -d)
cd "$TEMP_BUILD_DIR"

echo "   Cloning repository..."
git clone --depth 1 "https://github.com/${REPO}.git" . 2>/dev/null

echo "   Building binary..."
go build -ldflags="-s -w" -o "${EXTENSION_NAME}" ./cmd/gh-follow

# Move to final location
mv "${EXTENSION_NAME}" "$SCRIPT_DIR/"
chmod +x "$SCRIPT_DIR/${EXTENSION_NAME}"

# Cleanup
rm -rf "$TEMP_BUILD_DIR"

echo "✅ ${EXTENSION_NAME} built and installed successfully!"
echo ""
echo "📖 Usage:"
echo "   gh follow list              # List users you follow"
echo "   gh follow followers         # List your followers"
echo "   gh follow follow <user>     # Follow a user"
echo "   gh follow unfollow <user>   # Unfollow a user"
echo "   gh follow --help            # Show all options"
