#!/bin/bash
# gh-follow - GitHub CLI extension for managing follow relationships
# This script is used by 'gh extension install' to install the extension

set -e

EXTENSION_NAME="gh-follow"
REPO="h1s97x/gh-follow"
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"

# Detect OS and architecture
OS=$(uname -s | tr '[:upper:]' '[:lower:]')
ARCH=$(uname -m)

# Map architecture
case $ARCH in
    x86_64|amd64) ARCH="amd64" ;;
    aarch64|arm64) ARCH="arm64" ;;
    *)
        echo "⚠️  Unsupported architecture: $ARCH, building from source..."
        BUILD_FROM_SOURCE=true
        ;;
esac

# Map OS and set archive format
FORMAT="tar.gz"
case $OS in
    darwin)
        BINARY="${EXTENSION_NAME}-darwin-${ARCH}"
        ;;
    linux)
        BINARY="${EXTENSION_NAME}-linux-${ARCH}"
        ;;
    mingw*|msys*|cygwin*|windows*)
        BINARY="${EXTENSION_NAME}-windows-${ARCH}"
        FORMAT="zip"
        OS="windows"
        ;;
    *)
        echo "⚠️  Unsupported OS: $OS, building from source..."
        BUILD_FROM_SOURCE=true
        ;;
esac

# Try to download pre-built binary
if [ "$BUILD_FROM_SOURCE" != true ]; then
    echo "🔍 Checking for pre-built binary..."
    
    # Get latest release
    LATEST=$(gh api "repos/${REPO}/releases/latest" 2>/dev/null || echo "")
    
    if [ -n "$LATEST" ]; then
        VERSION=$(echo "$LATEST" | grep -m1 '"tag_name"' | cut -d'"' -f4)
        echo "📦 Found release: $VERSION"
        
        VERSION_NUM="${VERSION#v}"
        
        # Try actual release format: gh-follow_{version}_{os}_{arch}.{format}
        ARCHIVE="${EXTENSION_NAME}_${VERSION_NUM}_${OS}_${ARCH}.${FORMAT}"
        DOWNLOAD_URL="https://github.com/${REPO}/releases/download/${VERSION}/${ARCHIVE}"
        
        if curl -sLf "$DOWNLOAD_URL" -o /dev/null 2>&1; then
            echo "⬇️  Downloading ${ARCHIVE}..."
            cd "$SCRIPT_DIR"
            
            if [ "$FORMAT" = "zip" ]; then
                curl -sL "$DOWNLOAD_URL" -o temp.zip
                unzip -o temp.zip
                rm -f temp.zip
            else
                curl -sL "$DOWNLOAD_URL" | tar -xzf - 2>/dev/null
            fi
            
            # Find and rename the binary to match script name (no extension)
            if [ -f "${EXTENSION_NAME}.exe" ]; then
                mv "${EXTENSION_NAME}.exe" "$EXTENSION_NAME"
                chmod +x "$EXTENSION_NAME"
                echo "✅ Installed ${EXTENSION_NAME} ${VERSION}"
                exit 0
            elif [ -f "$BINARY" ]; then
                mv "$BINARY" "$EXTENSION_NAME"
                chmod +x "$EXTENSION_NAME"
                echo "✅ Installed ${EXTENSION_NAME} ${VERSION}"
                exit 0
            elif [ -f "${BINARY}.exe" ]; then
                mv "${BINARY}.exe" "$EXTENSION_NAME"
                chmod +x "$EXTENSION_NAME"
                echo "✅ Installed ${EXTENSION_NAME} ${VERSION}"
                exit 0
            fi
        fi
    fi
    
    echo "⚠️  Pre-built binary not available, building from source..."
fi

# Build from source
echo "🔨 Building from source..."

if ! command -v go &> /dev/null; then
    echo "❌ Error: Go is not installed."
    echo "Please install Go from: https://golang.org/doc/install"
    exit 1
fi

GO_VERSION=$(go version | awk '{print $3}' | sed 's/go//')
echo "   Go version: $GO_VERSION"

cd "$SCRIPT_DIR"
go build -ldflags="-s -w" -o "${EXTENSION_NAME}" ./cmd/gh-follow
chmod +x "${EXTENSION_NAME}"

echo "✅ ${EXTENSION_NAME} built and installed successfully!"
echo ""
echo "📖 Usage:"
echo "   gh follow list              # List users you follow"
echo "   gh follow followers         # List your followers"
echo "   gh follow follow <user>     # Follow a user"
echo "   gh follow unfollow <user>   # Unfollow a user"
echo "   gh follow --help            # Show all options"
